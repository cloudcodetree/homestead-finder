# Dependencies
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/.vite/

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Environment / secrets
.env
.env.local
.env.*.local
.env.deploy
scraper/config_local.py

# Claude Code local settings (user-specific overrides)
.claude/settings.local.json

# Data snapshots (only keep latest)
data/listings_*.json
data/notified.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
.screenshots/
frontend/public/data/
data/scraper.log
data/cache/
data/ai_costs.jsonl
.claude/worktrees/

# Dev-only convenience symlink — Vite serves data/ via this in dev;
# CI deploys copy data/*.json into frontend/dist/data/ explicitly.
frontend/public/data

# Local scheduler state
.claude/scheduled_tasks.lock

# Runtime throttle state — per-day per-domain request counters
data/scrape_quota.json

# SQLite scraper store — derived from listings.json on every run.
# Not checked in: it's a working store, not the shipped artifact.
data/corpus.sqlite
data/corpus.sqlite-shm
data/corpus.sqlite-wal

# Image-placeholder fingerprint registry — populated by
# `python -m scraper.image_validation --learn`. Could be checked in
# once stable but for now treat it as local-only state.
data/_image_placeholders.json

# Supabase CLI working directory — per-machine state (linked project,
# pooler URL, version pins). Standard Supabase template ignores this.
supabase/.temp/
