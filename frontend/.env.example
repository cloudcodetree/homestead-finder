# Copy to .env.local and fill in values from your Supabase project
# (Project Settings → API in the Supabase dashboard). Both values are
# safe to ship in the built bundle — the anon key is the public API
# key; database-level access is gated by Row-Level Security policies.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXX

# Stripe Payment Link URLs from Dashboard → Payment Links. Both are
# public URLs (anyone can navigate to them) so safe to ship in the
# bundle. See context/STRIPE_SETUP.md for the full operator runbook.
VITE_STRIPE_LINK_MONTHLY=https://buy.stripe.com/XXX_monthly
VITE_STRIPE_LINK_ANNUAL=https://buy.stripe.com/XXX_annual

# Optional: Stripe Customer Portal URL for "Manage subscription" link.
# Set after enabling the Customer Portal in Stripe → Settings → Billing.
VITE_STRIPE_CUSTOMER_PORTAL=https://billing.stripe.com/p/login/XXX
