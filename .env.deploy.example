# Server-only secrets. Sourced by scripts/deploy-stripe-webhook.sh.
# Copy to .env.deploy (gitignored) and fill in.
#
# These do NOT belong in frontend/.env.local — Vite never reads them
# and putting them there means every "I'll just paste my .env" debug
# moment leaks production credentials.
#
# Pattern: only VITE_* vars go in frontend/.env.local. Everything else
# lives here.

# ── Stripe ─────────────────────────────────────────────────────────
# Get from Stripe Dashboard → Developers → API keys → Secret key
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Get from Stripe Dashboard → Webhooks → click your destination → Reveal signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Get from Stripe Dashboard → Product catalog → click each product → copy price_xxx
STRIPE_PRICE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_ANNUAL=price_REPLACE_ME

# ── Supabase ───────────────────────────────────────────────────────
# NOT used by the deploy script (Supabase auto-injects its own URL +
# secret key into Edge Functions). Kept here so OTHER local server
# scripts (e.g. scraper/alerts.py, scraper/project_files_extract.py,
# scraper/rank_fit.py) can source the same file.
#
# API Keys 2.0 — prefer `SUPABASE_SECRET_KEY` (sb_secret_…). The
# legacy `SUPABASE_SERVICE_ROLE_KEY` (eyJ…) is kept in the codebase
# as a fallback for projects that haven't disabled JWT-based keys.
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME
# Legacy fallback — leave blank if you've disabled JWT-based API keys
# in your Supabase project's API settings.
# SUPABASE_SERVICE_ROLE_KEY=eyJREPLACE_ME
